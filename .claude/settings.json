{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bun install)",
      "Bash(bun install *)",
      "Bash(bun add *)",
      "Bash(bun pm *)",
      "Bash(bun test *)",
      "Bash(bun run *)",
      "Bash(bun --version)",
      "Bash(bunx biome *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git mv *)",
      "Bash(git config *)",
      "Bash(git check-ignore *)",
      "Bash(gh api *)",
      "Bash(gh auth *)",
      "Bash(gh label *)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ]
  },
  "enabledPlugins": {
    "slow-powers@slowdini": false,
    "superpowers@claude-plugins-official": false
  }
}
